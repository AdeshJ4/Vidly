@model IEnumerable<Vidly.Models.Movie>

@{
    ViewData["Title"] = "Movies";
}

<!DOCTYPE html>
<html>
<body>

    <div class="container p-3">
        <div class="col-6">
            <h2 class="text-primary">Movies</h2>
        </div>
    </div>

    @if (!Model.Any())
    {
        <p>We don't have any movies yet.</p>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Movie</th>
                    <th>Genre</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var movie in Model)
                {
                    <tr>
                        <td>
                            <a asp-route-id="@movie.Id" asp-controller="Movies" asp-action="Details">@movie.Name</a>
                        </td>

                        <td>
                            @movie.Genre.Name
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</body>
</html>