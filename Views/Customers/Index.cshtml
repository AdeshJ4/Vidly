@{
    ViewData["Title"] = "Customers";
}`

<!DOCTYPE html>
<html>
<body>

    <div class="container p-3">
        <div class="col-6">
            <h2 class="text-primary">Customers</h2>           
        </div>
    </div>


        <table id="customers" class="table table-bordered" style="">
            <thead class="thead-light">
                <tr>
                    <a asp-controller="Customers" asp-action="CustomerForm" class="btn btn-primary mb-3">New Customer</a>
                </tr>
                <tr class="text-center">
                    <th>Customer ID</th>
                    <th>Customer Name</th>
                    <th>Membership Type</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>


    @section scripts{
        <script src="~/js/datatable_file.js"></script>
    }

</body>
</html>