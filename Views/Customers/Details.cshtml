@model Vidly.DTOs.CustomerDto

@{
    ViewData["Title"] = "Details";
}

<div class="container p-3">
        <div class="col-6">
        <h2 class="text-primary">@Model.Name</h2>
        </div>
    </div>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Customer ID</th>
            <th>Customer Name</th>
            <th>Membership Type</th>
            <th>Edit</th>
            <th>Delete</th>
        </tr>
        <tr></tr>
    </thead>
    <tbody>
       
            <tr>
               
                <td>
                    @Model.Id
                </td>

                <td>
                    @Model.Name
                </td>
                
                <td>
                    @Model.MembershipType.Name
                </td>

                <td>
                    <a asp-route-id="@Model.Id" asp-controller="Customers" asp-action="Edit" class="btn btn-primary">Edit</a>
                </td>
                
                <td>
                    <a asp-route-id="@Model.Id" asp-controller="Customers" asp-action="Delete" class="btn btn-primary">Delete</a>
                </td>

            
            </tr>
        
    </tbody>
</table>