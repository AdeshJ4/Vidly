@model Vidly.Models.Customer

@{
    ViewData["Title"] = "Details";
}

<div class="container p-3">
        <div class="col-6">
        <h2 class="text-primary">@Model.Name</h2>
        </div>
    </div>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Customer ID</th>
            <th>Customer Name</th>
            <th>Duration</th>
            <th>Discount Rate</th>
            <th>Membership Type</th>
            <th>BirthDate</th>
        </tr>
        <tr></tr>
    </thead>
    <tbody>
       
            <tr>
               
                <td>
                    @Model.Id
                </td>

                <td>
                    @Model.Name
                </td>

                <td>
                    @Model.MembershipType.DurationInMonths months
                </td>

                <td>
                    @Model.MembershipType.DiscountRate%
                </td>

                <td>
                    @Model.MembershipType.Name
                </td>

                @if (Model.BirthDate.HasValue){
                    <td>
                        @Model.BirthDate.Value.ToShortDateString()
                    </td>
                }else{
                    <td>
                        -
                    </td>
                }

            
            </tr>
        
    </tbody>
</table>