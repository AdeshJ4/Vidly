@model Vidly.Models.Customer

@{
    ViewData["Title"] = "Details";
}

<div class="container p-3">
        <div class="col-6">
            <h2 class="text-primary">Details</h2>
        </div>
    </div>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Customer ID</th>
            <th>Customer Name</th>
            <th>Duration</th>
            <th>Discount Rate</th>
        </tr>
        <tr></tr>
    </thead>
    <tbody>
       
            <tr>
               
                <td>
                    @Model.Id
                </td>

                <td>
                    @Model.Name
                </td>

                <td>
                    @Model.MembershipType.DurationInMonths
                </td>

                <td>
                    @Model.MembershipType.DiscountRate%
                </td>
            </tr>
        
    </tbody>
</table>